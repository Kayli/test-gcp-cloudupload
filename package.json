{
  "name": "docstore-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --names api,ui --prefix-colors cyan,magenta \"npm run dev:api\" \"npm run dev:client\"",
    "dev:api": "ALLOW_DEV_AUTH=1 uvicorn main:app --host 0.0.0.0 --port 3000 --reload",
    "dev:client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "pytest"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.2.1",
    "vite": "^5.4.0"
  }
}
