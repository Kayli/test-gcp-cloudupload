# Example devcontainer environment file (safe to commit).
# Copy to .devcontainer/.env and fill real values for local development.

# Path inside the container where your GCP service account key is mounted (optional)
GOOGLE_APPLICATION_CREDENTIALS=/workspaces/.secrets/gcp-sa-key.json

# OAuth client id used by the web app (non-secret)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# Enable developer auth flow (1 or 0)
ALLOW_DEV_AUTH=1

# Chrome remote debugging endpoint on the host (used when USE_HOST_BROWSER=1)
CHROME_REMOTE_DEBUGGING_URL=http://host.docker.internal:9222

# Use the host's Chrome Canary via CDP when set to 1. CI should set to 0.
USE_HOST_BROWSER=1
