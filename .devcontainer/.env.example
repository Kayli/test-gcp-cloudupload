# Example devcontainer environment file (safe to commit).
# Copy to .devcontainer/.env and fill real values for local development.

# Path inside the container where your GCP service account key is mounted (optional)
GOOGLE_APPLICATION_CREDENTIALS=/workspaces/.secrets/gcp-sa-key.json

# GCP project number (used for GCP APIs / service identity)
GOOGLE_PROJECT_NUMBER=
# OAuth 2.0 Web Client ID from Google Cloud Console > APIs & Services > Credentials
# Format: <numbers>-<hash>.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_ID=

# Enable developer auth flow (1 or 0)
ALLOW_DEV_AUTH=1

# Chrome remote debugging endpoint on the host (used when USE_HOST_BROWSER=1)
CHROME_REMOTE_DEBUGGING_URL=http://host.docker.internal:9222

# Use the host's Chrome Canary via CDP when set to 1. CI should set to 0.
USE_HOST_BROWSER=1

# ── MinIO (dev object storage) ────────────────────────────────────────────────
# Start MinIO with:  docker compose up -d minio
# Console UI:        http://localhost:9001
#
# MINIO_ENDPOINT     – URL the FastAPI server uses to reach MinIO.
#   In the devcontainer (host.docker.internal is the Docker host):
#     http://host.docker.internal:9000
#   If FastAPI and MinIO are on the same machine / same compose network:
#     http://localhost:9000
#
# MINIO_PUBLIC_URL   – URL embedded in the signed URL that the *browser* uses.
#   Usually http://localhost:9000 (port-forwarded to the host).
#   Leave empty to reuse MINIO_ENDPOINT.
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=uploads

# ── GCS (prod object storage) ─────────────────────────────────────────────────
# Set GCS_BUCKET to switch from MinIO to GCS.  Leave blank for dev.
GCS_BUCKET=
