{
  "name": "docstore-prototype",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker"
      ]
    }
  },
  "forwardPorts": [3000],
  "runArgs": ["--add-host=host.docker.internal:host-gateway"],
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "remoteUser": "node",
  "mounts": [
    "source=${localWorkspaceFolder}/.secrets,target=/workspaces/.secrets,type=bind,consistency=cached",
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "remoteEnv": {
    "GOOGLE_APPLICATION_CREDENTIALS": "/workspaces/.secrets/gcp-sa-key.json",
    "GOOGLE_CLIENT_ID": "117938197293975641947.apps.googleusercontent.com",
    "ALLOW_DEV_AUTH": "1",
    "CHROME_REMOTE_DEBUGGING_URL": "http://host.docker.internal:9222"
  }
}

