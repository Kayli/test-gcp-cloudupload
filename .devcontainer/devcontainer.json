{
  "name": "docstore-prototype",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker"
      ]
    }
  },
  "forwardPorts": [3000],
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "remoteUser": "node",
  // TODO: uncomment once you have the key file and GOOGLE_APPLICATION_CREDENTIALS set on the host
  // "mounts": [
  //   "source=${localEnv:GOOGLE_APPLICATION_CREDENTIALS},target=/workspaces/.secrets/gcloud-key,type=bind,consistency=cached"
  // ],
  "remoteEnv": {
    "GOOGLE_APPLICATION_CREDENTIALS": "/workspaces/.secrets/gcloud-key"
  }
}
